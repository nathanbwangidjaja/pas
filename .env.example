# ============================================================
# environment variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored by Next.js — NEVER commit real keys.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser; everything
# else is server-only. Keep secrets out of NEXT_PUBLIC_*.
# ============================================================

# ----- App -----
# Public base URL of the app (used to build shareable bill + pay links).
# Local dev: http://localhost:3000   Production: your deployed URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret for signing capability tokens on shareable bill links.
# Generate one with:  openssl rand -base64 32
APP_SECRET=

# ----- Supabase (database, auth, storage, realtime) -----
# From your Supabase project dashboard: Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Full admin access that bypasses row-level security —
# NEVER expose this to the browser or prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string, used only to run the schema migration (not at runtime).
# Supabase dashboard -> Settings -> Database -> Connection string -> URI (Session pooler).
# It already includes your database password.
DATABASE_URL=

# ----- Anthropic (Claude) — receipt OCR / line-item extraction -----
# From console.anthropic.com -> API Keys. Server-only.
ANTHROPIC_API_KEY=
# Fast/cheap model for clean receipts; stronger model for hard ones
# (crumpled, faded, handwritten, or when the math check fails).
ANTHROPIC_OCR_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_OCR_MODEL_STRONG=claude-opus-4-8

# ----- Email (passwordless magic-link sign-in for the organizer) -----
# Supabase's built-in mailer is dev-only and rate-limited; use a real
# provider in production. Resend: resend.com -> API Keys. Server-only.
# Optional for local dev (Supabase can send test emails).
RESEND_API_KEY=
EMAIL_FROM="pas <login@yourdomain.com>"

# ============================================================
# PAYMENTS — IMPORTANT: Venmo and Zelle need NO API keys.
# Venmo charge links and Zelle QR codes are generated client-side from
# the organizer's own handle. No third-party Venmo/Zelle API/key exists
# for this — do not go looking for one. The app never touches money.
# ============================================================

# ----- Optional: PayPal (only if you later add PayPal as a rail) -----
# developer.paypal.com -> Apps & Credentials. Leave blank unless used.
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_ENV=sandbox

# ----- Optional: Rate limiting (protect the paid OCR endpoint from abuse) -----
# Upstash Redis: upstash.com. Recommended before going to production.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ----- Optional: Error monitoring / analytics -----
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
